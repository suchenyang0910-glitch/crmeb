APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
HOSTPORT = 3306
USERNAME = crmeb_user
PASSWORD = CHANGE_ME
DATABASE = crmeb_prod
PREFIX = eb_
CHARSET = utf8mb4
DEBUG = false

[LANG]
default_lang = zh-cn

[CACHE]
DRIVER = redis
CACHE_PREFIX = cache_crmeb_prod:
CACHE_TAG_PREFIX = cache_tag_crmeb_prod:

[REDIS]
REDIS_HOSTNAME = 127.0.0.1
PORT = 6379
REDIS_PASSWORD =
SELECT = 0

[QUEUE]
QUEUE_NAME = prod
